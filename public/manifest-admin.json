{
  "name": "Shayboub Admin Panel",
  "short_name": "Shayboub Admin",
  "description": "Admin dashboard for managing Shayboub reservations, menu, analytics, and staff.",
  "start_url": "/admin",
  "scope": "/admin",
  "display": "standalone",
  "background_color": "#0f172a",
  "theme_color": "#1e293b",
  "orientation": "any",
  "icons": [
    {
      "src": "/images/shayboub-logo.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/images/shayboub-logo.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    }
  ],
  "categories": ["business", "productivity"],
  "display_override": ["window-controls-overlay", "standalone"],
  "shortcuts": [
    {
      "name": "Reservations",
      "short_name": "Reservations",
      "description": "View and manage reservations",
      "url": "/admin/reservations",
      "icons": [{ "src": "/images/shayboub-logo.png", "sizes": "192x192" }]
    },
    {
      "name": "Menu Management",
      "short_name": "Menu",
      "description": "Manage menu items",
      "url": "/admin/menu",
      "icons": [{ "src": "/images/shayboub-logo.png", "sizes": "192x192" }]
    },
    {
      "name": "Analytics",
      "short_name": "Analytics",
      "description": "View analytics dashboard",
      "url": "/admin/analytics",
      "icons": [{ "src": "/images/shayboub-logo.png", "sizes": "192x192" }]
    },
    {
      "name": "Dashboard",
      "short_name": "Dashboard",
      "description": "Main dashboard",
      "url": "/admin",
      "icons": [{ "src": "/images/shayboub-logo.png", "sizes": "192x192" }]
    }
  ]
}
